# ============================================================
# OpenRouter-Provider Konfiguration
# ============================================================
# Diese Datei ist eine Vorlage. Kopiere sie nach `.env` und trage
# deinen echten API-Key ein. `.env` ist in .gitignore und wird
# NICHT ins Repo committet.
#
# Anleitung:
#   cp .env.example .env
#   # dann .env editieren und OPENROUTER_API_KEY eintragen
# ============================================================

# Pflicht: dein OpenRouter-API-Key
OPENROUTER_API_KEY=sk-or-v1-DEIN_KEY_HIER

# Optional: Standard-Modell (kann pro Buch in config/books.yaml
# unter `ai.model` überschrieben werden).
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Optional: OpenRouter-Endpoint (Default reicht in der Regel)
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Optional: App-Metadaten (OpenRouter empfiehlt diese Header)
OPENROUTER_APP_NAME=peter-the-one
OPENROUTER_APP_URL=https://github.com/LitttleLions/peter-the-one-creator
